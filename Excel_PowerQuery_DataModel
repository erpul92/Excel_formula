13. CREATE CLEAN_ISSUE1_MAP
================================================================================

1. Right-click Tbl_Issue1.
2. Choose Reference.
3. Rename to:

Clean_Issue1_Map

4. Open Advanced Editor.
5. Use this code:

let
    Source = Tbl_Issue1,
    KeepColumns = Table.SelectColumns(Source, {"Priority", "Keyword", "Keyword2", "Category"}),
    ChangeTypes = Table.TransformColumnTypes(
        KeepColumns,
        {
            {"Priority", Int64.Type},
            {"Keyword", type text},
            {"Keyword2", type text},
            {"Category", type text}
        }
    ),
    CleanText = Table.TransformColumns(
        ChangeTypes,
        {
            {"Keyword", each if _ = null then "" else Text.Lower(Text.Trim(Text.From(_))), type text},
            {"Keyword2", each if _ = null then "" else Text.Lower(Text.Trim(Text.From(_))), type text},
            {"Category", each if _ = null then "Others Issues" else Text.Trim(Text.From(_)), type text}
        }
    ),
    RemoveBlankKeyword = Table.SelectRows(CleanText, each [Keyword] <> "")
in
    RemoveBlankKeyword

6. Set load to Connection Only.


